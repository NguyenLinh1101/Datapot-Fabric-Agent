relationship Sales_Date
	fromColumn: Sales.Date
	toColumn: Date.Date

relationship Sales_Product
	fromColumn: Sales.ProductID
	toColumn: Product.ProductID

relationship Sales_Customer
	fromColumn: Sales.CustomerID
	toColumn: Customer.CustomerID

relationship Sales_Campaign
	fromColumn: Sales.CampaignID
	toColumn: Campaign.CampaignID

relationship Customer_Geo
	fromColumn: Customer.ZipCode
	toColumn: Geo.Zip

relationship BudgetForecast_Date
	fromColumn: Budget_Forecast.BudgetDate
	toColumn: Date.Date
